#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/sbin/idclass
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    # 可选：清理 TC 程序，但 idclass 退出后内核会自动清理（取决于 map pinning）
    killall idclass 2>/dev/null
}