	option enabled '1'
	option min_bytes '10000'       # 10 KB
	option min_connections '10'     # 10 个并发连接

# 高吞吐服务检测
config high_throughput_service_detection
	option enabled '1'
	option min_bytes '1000000'      # 1 MB
	option min_connections '3'       # 3 个并发连接

# ========== 通用 DSCP 分类参考 ==========
# 语音 (EF, 46)          → 最高优先级
# 多媒体会议 (AF41, 34)  → 视频会议/互动直播
# 多媒体流 (CS4, 32)     → 点播视频、短视频播放
# 事务数据 (AF21, 18)    → 交互式业务（如购物下单）
# 批量数据 (AF11, 10)    → 下载、预缓存
# 清扫器 (CS1, 8)        → 最低优先级
# 关键操作 (CS5, 40)     → 支付、认证等关键事务

